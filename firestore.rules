rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection
    match /users/{userId} {
      // Authenticated users can read all users
      allow read: if request.auth != null;

      // Users can write their own doc on sign-up
      // Admins can create/update/delete any user
      allow create: if request.auth != null
                    && (request.auth.uid == userId
                        || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      allow update: if request.auth != null
                    && (request.auth.uid == userId
                        || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      allow delete: if request.auth != null
                    && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Entries collection
    match /entries/{entryId} {
      // Authenticated users can read all entries
      allow read: if request.auth != null;

      // Users can create/update their own entries
      // Admins can write any entry
      allow create, update: if request.auth != null
                            && (request.resource.data.userId == request.auth.uid
                                || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      // Delete uses resource.data (existing doc), not request.resource (which is null on delete)
      allow delete: if request.auth != null
                    && (resource.data.userId == request.auth.uid
                        || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    // Shifts collection
    match /shifts/{shiftId} {
      // Authenticated users can read all shifts
      allow read: if request.auth != null;

      // Only admins can create/update/delete shifts
      allow write: if request.auth != null
                   && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}
